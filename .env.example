# Database
DATABASE_URL="postgresql://..."

# Media Extractor Method
# Options: auto | ytdlp | snapvid | browser
# - auto: Try yt-dlp first, fallback to snapvid, then agent-browser
# - ytdlp: Use yt-dlp only
# - snapvid: Use snapvid.net API only
# - browser: Use agent-browser only
MEDIA_EXTRACTOR_METHOD=auto
