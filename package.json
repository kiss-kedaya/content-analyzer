{
  "name": "content-analyzer",
  "version": "1.0.0",
  "description": "AI-powered content analysis system with automated scraping",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "fix": "node scripts/fix-missing-fields.js",
    "fix:titles": "node scripts/fix-missing-fields.js --title-only",
    "fix:summaries": "node scripts/fix-missing-fields.js --summary-only",
    "fix:tech": "node scripts/fix-missing-fields.js --tech-only",
    "fix:adult": "node scripts/fix-missing-fields.js --adult-only",
    "fix:check": "node scripts/fix-missing-fields.js --dry-run",
    "test:source": "node test-source-normalization.js",
    "reanalyze:all": "node scripts/reanalyze-and-reclassify.js",
    "reanalyze:dry": "node scripts/reanalyze-and-reclassify.js --dry-run",
    "reanalyze:debug": "set DEBUG=1 && node scripts/reanalyze-and-reclassify.js",
    "reanalyze:debug-ai": "set DEBUG_AI=1 && node scripts/reanalyze-and-reclassify.js",
    "reanalyze:sample": "set DEBUG_AI=1 && set LIMIT=3 && node scripts/reanalyze-and-reclassify.js"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@t3-oss/env-nextjs": "^0.13.10",
    "@types/nprogress": "^0.2.3",
    "jose": "^6.1.3",
    "lucide-react": "^0.576.0",
    "next": "^15.1.6",
    "nprogress": "^0.2.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^5.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "yt-dlp-wrap": "^2.3.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.1.6",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tsx": "^4.21.0",
    "typescript": "^5.7.2"
  }
}
