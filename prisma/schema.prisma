// Prisma schema for content analyzer
// Database: Neon PostgreSQL

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Content {
  id         String   @id @default(cuid())
  source     String   // twitter, xiaohongshu, linuxdo, etc.
  url        String   @unique
  title      String?
  summary    String   @db.Text
  content    String   @db.Text  // 完整内容
  score      Float
  analyzedBy String?  // 分析者（Agent 名称）
  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  favorited  Boolean  @default(false)  // 收藏状态
  favoritedAt DateTime?  // 收藏时间

  // 统一媒体结构：仅对 source=X 回填并使用
  mediaUrls  String[] @default([])
  mediaFetchedAt DateTime?
  mediaSourceUrl String?
  
  @@index([source])
  @@index([score])
  @@index([analyzedAt])
  @@index([createdAt])
  @@index([favorited])
}

model AdultContent {
  id         String   @id @default(cuid())
  source     String   // twitter, xiaohongshu, linuxdo, etc.
  url        String   @unique
  title      String?
  summary    String   @db.Text
  content    String   @db.Text  // 完整内容
  score      Float
  analyzedBy String?  // 分析者（Agent 名称）
  analyzedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  favorited  Boolean  @default(false)  // 收藏状态
  favoritedAt DateTime?  // 收藏时间

  // 统一媒体结构：目前主要用于 source=X
  mediaUrls  String[] @default([])
  mediaFetchedAt DateTime?
  mediaSourceUrl String?
  
  @@index([source])
  @@index([score])
  @@index([analyzedAt])
  @@index([createdAt])
  @@index([favorited])
}

model MediaCache {
  id           String   @id @default(cuid())
  url          String   @unique
  status       String
  rawResponse  Json
  parsedMedia  Json
  lastFetchedAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([status])
  @@index([lastFetchedAt])
}

model SourceCache {
  id            String   @id @default(cuid())
  url           String   @unique
  provider      String   // jina | defuddle
  status        String   // ok | failed
  rawResponse   Json?
  title         String?
  text          String   @db.Text
  wordCount     Int?
  sha256        String?
  lastFetchedAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([provider])
  @@index([status])
  @@index([lastFetchedAt])
}
